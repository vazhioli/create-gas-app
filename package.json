{
  "name": "create-gas-app",
  "version": "0.4.2",
  "description": "The modern CLI to scaffold Google Apps Script apps with React, Vue, Svelte, or SolidJS",
  "type": "module",
  "bin": {
    "create-gas-app": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "release-it"
  },
  "keywords": [
    "google-apps-script",
    "gas",
    "scaffold",
    "create",
    "react",
    "vue",
    "svelte",
    "solidjs",
    "vite",
    "clasp"
  ],
  "author": "Pradeep",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vazhioli/create-gas-app"
  },
  "homepage": "https://github.com/vazhioli/create-gas-app#readme",
  "bugs": {
    "url": "https://github.com/vazhioli/create-gas-app/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "execa": "^9.0.0",
    "fs-extra": "^11.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "release-it": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits",
        "infile": "CHANGELOG.md"
      }
    }
  }
}
